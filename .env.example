# PayLoop Dashboard Environment Variables

# Database (same as checkout)
DATABASE_URL=postgresql://user:pass@host:5432/payloop

# Session secret (CHANGE THIS!)
SESSION_SECRET=your-random-secret-key-here

# Admin credentials
ADMIN_EMAIL=admin@mellone.co
ADMIN_PASSWORD_HASH= # Will be auto-generated on first run

# Node environment
NODE_ENV=production