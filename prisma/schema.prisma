// PayLoop Dashboard - Introspected from actual database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id               String          @id @default(uuid())
  email            String          @unique
  firstName        String
  lastName         String
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  country          String          @default("US")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  stripeCustomerId String?
  orders           Order[]
  paymentMethods   PaymentMethod[]
  subscriptions    Subscription[]
}

model PaymentMethod {
  id             String         @id @default(uuid())
  customerId     String
  nmiToken       String         @unique
  cardLast4      String
  cardType       String
  cardExpMonth   String
  cardExpYear    String
  billingAddress String?
  billingCity    String?
  billingState   String?
  billingZip     String?
  billingCountry String?        @default("US")
  isDefault      Boolean        @default(false)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  orders         Order[]
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Subscription   Subscription[]
}

model Order {
  id               String         @id @default(uuid())
  customerId       String
  subscriptionId   String?
  paymentMethodId  String?
  type             String
  subtotal         Float
  tax              Float          @default(0)
  shipping         Float          @default(0)
  total            Float
  currency         String         @default("USD")
  items            String
  nmiTransactionId String?        @unique
  nmiAuthCode      String?
  nmiResponse      String?
  status           String         @default("pending")
  errorMessage     String?
  threeDsRequired  Boolean        @default(false)
  threeDsAuthData  String?
  refundedAt       DateTime?
  refundAmount     Float?
  chargebackAt     DateTime?
  chargebackAmount Float?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  shopifyOrderId   String?
  shopifyOrderName String?
  gatewayId        String?
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentMethod    PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  Subscription     Subscription?  @relation(fields: [subscriptionId], references: [id])
}

model PaymentGateway {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String    @unique
  displayName    String?
  type           String?   @default("nmi")
  isActive       Boolean?  @default(true)
  isDefault      Boolean?  @default(false)
  nmiSecurityKey String?
  nmiEndpoint    String?
  nmiMerchantId  String?
  monthlyCap     Float?    // Monthly processing limit in USD
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model Subscription {
  id                       String                     @id @default(uuid())
  customerId               String
  paymentMethodId          String
  name                     String
  description              String?
  amount                   Float
  originalAmount           Float
  currency                 String                     @default("USD")
  interval                 String
  intervalCount            Int                        @default(1)
  billingCycleStart        DateTime                   @default(now())
  nextBillDate             DateTime?
  lastBillDate             DateTime?
  totalBillings            Int                        @default(0)
  status                   String                     @default("active")
  cancelledAt              DateTime?
  cancelReason             String?
  threeDsAuthData          String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  gatewayId                String?
  Order                    Order[]
  customer                 Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  PaymentMethod            PaymentMethod              @relation(fields: [paymentMethodId], references: [id])
  SubscriptionPriceHistory SubscriptionPriceHistory[]
}

model AdminUser {
  id           String    @id
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
}

model Setting {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String    @unique
  value     String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
}

model SubscriptionPriceHistory {
  id             String       @id
  subscriptionId String
  oldAmount      Float
  newAmount      Float
  reason         String?
  changedBy      String?
  createdAt      DateTime     @default(now())
  Subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model SubscriptionProduct {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  price          Float?    @default(0)
  interval       String?   @default("month")
  intervalCount  Int?      @default(1)
  showOnCheckout Boolean?  @default(true)
  gatewayId      String?   @db.Uuid
  isActive       Boolean?  @default(true)
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @db.Timestamp(6)
}